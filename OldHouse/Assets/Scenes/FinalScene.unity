  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 0.025201082, g: 0, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 28578d613818ae943888eb806b86f239, type: 3}
    m_FontSize: 14
    m_FontStyle: 0
    m_BestFit: 1
    m_MinSize: 10
    m_MaxSize: 120
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u042F \u0432\u044B\u0431\u0440\u0430\u043B\u0441\u044F \u0438\u0437 \u044D\u0442\u043E\u0433\u043E
    \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0433\u043E \u0434\u043E\u043C\u0430
    \u0438, \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E, \u043E\u043D
    \u0438\u0441\u0447\u0435\u0437  \u043F\u0440\u043E\u0432\u0430\u043B\u0438\u0432\u0448\u0438\u0441\u044C
    \u043F\u043E\u0434 \u0437\u0435\u043C\u043B\u044E! \u0410 \u0432\u043E\u043A\u0440\u0443\u0433
    \u0442\u0435\u043F\u0435\u0440\u044C \u0447\u0443\u0434\u0435\u0441\u043D\u044B\u0439
    \u043B\u0435\u0441. \u041D\u043E \u0441\u0430\u043C\u043E\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    - \u0437\u0430\u0432\u0435\u0442\u043D\u0430\u044F \u041A\u041D\u0418\u0413\u0410
    \u0443 \u043C\u0435\u043D\u044F !!!"
